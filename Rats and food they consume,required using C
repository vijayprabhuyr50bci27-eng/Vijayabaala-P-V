#include<stdio.h>
int ratsAndFood(int r,int unit,int arr[],int n)
{
    int totalFood=0;
    int requiredFood=r*unit;
    int i;
    if(arr==NULL)
    return -1;
    for(i=0;i<n;i++)
    {
        totalFood+=arr[i];
        if(totalFood>=requiredFood)
        return i+1;
    }
    return 0;
}
int main()
{
    int r,unit,arr[50],n,i;
    printf("Enter no.of rats:");
    scanf("%d",&r);
    printf("Enter the units each rats consumes:");
    scanf("%d",&unit);
    printf("Enter no.of houses:");
    scanf("%d",&n);
    printf("Enter food units available in each house:");
    for(i=0;i<n;i++)
    {
        printf("\nHouse %d :",i+1);
        scanf("%d",&arr[i]);
    }
    int result=ratsAndFood(r,unit,arr,n);
    printf("Output:%d",result);
    return 0;
}

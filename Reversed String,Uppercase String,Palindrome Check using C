#include <stdio.h>
#include <string.h>
#include <ctype.h>
void reverseString(char str[])
{
 int n = strlen(str);
 for (int i = 0; i < n / 2; i++)
 {
 char temp = str[i];
 str[i] = str[n - i - 1];
 str[n - i - 1] = temp;
 }
}
void toUpperCase(char str[])
{
 for (int i = 0; str[i]; i++) 
 {
 str[i] = toupper(str[i]);
 }
}
int isPalindrome(char str[])
{
 int n = strlen(str);
 for (int i = 0; i < n / 2; i++)
 {
 if (str[i] != str[n - i - 1])
 {
 return 0;
 }
 }
 return 1;
}
